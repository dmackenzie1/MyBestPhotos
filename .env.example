POSTGRES_DB=photo_curator
POSTGRES_USER=photo_curator
POSTGRES_PASSWORD=photo_curator
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Host directories to mount into containers
PHOTO_ROOT=./sample-photos

# Preferred root configuration for Python runner (CSV list)
PHOTO_INGEST_ROOTS=/photos/library

PHOTO_CURATOR_DB_DSN=postgresql://photo_curator:photo_curator@localhost:5432/photo_curator
PHOTO_CURATOR_CACHE_DIR=.cache
PHOTO_CURATOR_THUMBS_DIR=.cache/thumbs
PHOTO_CURATOR_LOG_DIR=logs
PHOTO_CURATOR_REPORT_DIR=reports
PHOTO_CURATOR_CONFIG_PATH=config.toml
PHOTO_CURATOR_DESCRIPTION_PROVIDER=basic
PHOTO_CURATOR_LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
PHOTO_CURATOR_LMSTUDIO_MODEL=qwen2.5-vl-7b-instruct
PHOTO_CURATOR_LMSTUDIO_TIMEOUT_SECONDS=60

STUB_MODE=false
