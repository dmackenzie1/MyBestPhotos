POSTGRES_DB=photo_curator
POSTGRES_USER=photo_curator
POSTGRES_PASSWORD=photo_curator
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Single host directory mounted into containers for ingest scanning
PHOTO_INGEST_ROOT=./sample-photos

PHOTO_CURATOR_DB_DSN=postgresql://photo_curator:photo_curator@localhost:5432/photo_curator
PHOTO_CURATOR_CACHE_DIR=.cache
PHOTO_CURATOR_THUMBS_DIR=.cache/thumbs
PHOTO_CURATOR_LOG_DIR=logs
PHOTO_CURATOR_REPORT_DIR=reports
PHOTO_CURATOR_CONFIG_PATH=config.toml
PHOTO_CURATOR_DESCRIPTION_PROVIDER=basic
PHOTO_CURATOR_LMSTUDIO_BASE_URL=http://192.168.10.64:1234/v1
PHOTO_CURATOR_LMSTUDIO_MODEL=qwen3.6-35b-a3b
PHOTO_CURATOR_LMSTUDIO_TIMEOUT_SECONDS=60
PHOTO_CURATOR_INGEST_LIMIT=0
PHOTO_CURATOR_INGEST_SELECTION_STRATEGY=first

# Back-compat aliases (used only when PHOTO_CURATOR_* ingest vars are unset)
INGEST_FILE_LIMIT=0
INGEST_SELECTION_STRATEGY=first

STUB_MODE=false

# Optional when using docker-compose.prod.yml GPU overlay
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
